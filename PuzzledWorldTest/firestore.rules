rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Every user's own in-progress/completed puzzle data - only that
    // user can read or write it.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Shared puzzles are published ONLY by the moderateAndPublishSharedPuzzle
    // Cloud Function (via the Admin SDK, which bypasses these rules
    // entirely) after the image has passed moderation. Clients can fetch
    // a SPECIFIC shared puzzle by its exact ID (that's the point of the
    // share link - person-to-person, not discoverable) but can never
    // list/query the collection to browse every shared puzzle that
    // exists, and can never create or modify one directly.
    match /sharedPuzzles/{shareId} {
      allow get: if true;
      allow list: if false;
      allow write: if false;
    }

    // A write-only mailbox for flagged content - anyone (including
    // guests) can file a report, since keeping friction low for safety
    // reporting matters more than gating it behind sign-in. Nobody can
    // read, update, or delete a report from the client; only manual
    // review via the Firebase console/Admin SDK can see them.
    match /reports/{reportId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Gallery artwork added automatically by the addDailyGalleryArtwork
    // scheduled Cloud Function (via the Admin SDK, which bypasses these
    // rules) once it's passed SafeSearch. Publicly browsable, like the
    // bundled gallery - guests can list/read it too, but only the
    // Function can ever write a new entry.
    match /galleryArtworks/{artworkId} {
      allow get, list: if true;
      allow write: if false;
    }
  }
}
